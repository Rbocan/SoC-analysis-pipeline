# Copy this file to .env and fill in values before running locally without Docker defaults.
# .env is gitignored — never commit real credentials.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=soc
POSTGRES_PASSWORD=soc_secret           # CHANGE in production
POSTGRES_DB=soc_dashboard

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://soc:soc_secret@postgres:5432/soc_dashboard
REDIS_URL=redis://redis:6379/0
SECRET_KEY=dev-secret-key-change-in-production   # CHANGE in production — use: openssl rand -hex 32
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
